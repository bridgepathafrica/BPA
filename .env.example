# =============================================================================
# Bridgepath Africa — Environment Variable Reference
# =============================================================================
# Copy this file to `.env` and fill in your values before starting the server.
# Never commit `.env` to version control.
#
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the application to start.
# Variables marked [OPTIONAL] enable additional features when present.
# =============================================================================


# ── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/bridgepath


# ── Authentication ───────────────────────────────────────────────────────────
# [REQUIRED] HMAC-SHA256 signing secret for session tokens.
# Generate a strong random value: openssl rand -hex 64
TOKEN_SECRET=replace-with-64-char-random-hex-string

# [REQUIRED] PBKDF2 password hashing salt.
# Generate: openssl rand -hex 32
PASSWORD_SALT=replace-with-32-char-random-hex-string


# ── Application URLs ─────────────────────────────────────────────────────────
# [REQUIRED] Public base URL for OAuth redirect URIs and magic-link emails.
# Must match the domain the application is served from (no trailing slash).
OAUTH_BASE_URL=https://yourdomain.com

# [DEVELOPMENT ONLY] Overrides the base URL when running behind a tunnel / proxy
# (e.g. Replit dev domain). Leave empty in production.
APP_DEV_DOMAIN=


# ── OpenAI (CV Review) ───────────────────────────────────────────────────────
# [OPTIONAL] Without this the CV Review page returns a 503.
OPENAI_API_KEY=sk-...

# [OPTIONAL] Override the OpenAI API base URL (e.g. for Azure OpenAI or proxies).
# Defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=


# ── Email — Resend ───────────────────────────────────────────────────────────
# [OPTIONAL] Without this, verification and magic-link emails are skipped.
# Sign up at https://resend.com
RESEND_API_KEY=re_...


# ── OAuth Providers ───────────────────────────────────────────────────────────
# [OPTIONAL] Google OAuth 2.0. Create credentials at console.cloud.google.com.
# Redirect URI to register: {OAUTH_BASE_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [OPTIONAL] LinkedIn OAuth 2.0.
# Redirect URI to register: {OAUTH_BASE_URL}/api/auth/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=


# ── Payments — Stripe ────────────────────────────────────────────────────────
# [OPTIONAL] Without this, the Human HR Review upgrade button falls back to
# the contact form. Use the test key (sk_test_...) in non-production environments.
STRIPE_SECRET_KEY=sk_live_...


# ── Server ───────────────────────────────────────────────────────────────────
# [OPTIONAL] API server port. Defaults to 8080.
PORT=8080

# [OPTIONAL] Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# [OPTIONAL] Set to "production" to disable debug output and enable stricter
# security settings.
NODE_ENV=production


# ── Supabase (alternative DB/storage) ────────────────────────────────────────
# [OPTIONAL] Only required if using Supabase for file storage or auth.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
